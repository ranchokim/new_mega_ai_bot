# Telegram
TELEGRAM_BOT_TOKEN=1234567890:YOUR_TELEGRAM_BOT_TOKEN

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SEC=180
PIPELINE_TIMEOUT_SEC=300

# ChromaDB
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=conversation_memory
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# MCP 서버 설정(JSON 배열) - dotenv 파서 호환을 위해 반드시 한 줄 JSON 문자열로 작성
# 예시: filesystem + sqlite 서버
MCP_SERVERS_JSON=[{"name":"filesystem","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","."]},{"name":"sqlite","command":"npx","args":["-y","@modelcontextprotocol/server-sqlite","--db-path","./data.db"]}]
ENABLE_OPEN_INTERPRETER=false

# Logging
LOG_LEVEL=INFO
